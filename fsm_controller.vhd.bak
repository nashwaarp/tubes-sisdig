library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity fsm_controller is
    Port (
        clk             : in  STD_LOGIC;
        rst_n           : in  STD_LOGIC;
        
        -- Sinyal Status dari Datapath (Input untuk FSM)
        rx_data_ready   : in  STD_LOGIC; -- Sinyal dari Python bahwa ada data masuk
        buffer_full     : in  STD_LOGIC; -- Sinyal jika 1024 data sudah masuk RAM
        fft_done        : in  STD_LOGIC; -- Sinyal dari Butterfly Unit
        mag_done        : in  STD_LOGIC; -- Sinyal dari Magnitude Calc
        tx_done         : in  STD_LOGIC; -- Sinyal 1 frame selesai dikirim
        
        -- Sinyal Kontrol ke Datapath (Output dari FSM)
        en_rx           : out STD_LOGIC;
        en_ram_write    : out STD_LOGIC;
        en_fft          : out STD_LOGIC;
        en_mag          : out STD_LOGIC;
        en_tx           : out STD_LOGIC
    );
end fsm_controller;

architecture Behavioral of fsm_controller is

    -- Definisi Tipe Data untuk State
    type state_type is (IDLE, FILL_BUFFER, BIT_REVERSE, FFT_COMPUTE, MAGNITUDE, SEND_DATA);
    signal current_state, next_state : state_type;

begin

    -- =========================================================
    -- Process 1: Logika Sekuensial (Update State)
    -- Menggunakan Clock 50MHz dan Reset Asinkron
    -- =========================================================
    process(clk, rst_n)
    begin
        if rst_n = '0' then
            current_state <= IDLE;
        elsif rising_edge(clk) then
            current_state <= next_state;
        end if;
    end process;

    -- =========================================================
    -- Process 2: Logika Kombinasional (Transisi & Output)
    -- =========================================================
    process(current_state, rx_data_ready, buffer_full, fft_done, mag_done, tx_done)
    begin
        -- Nilai default output agar tidak terjadi Latch yang tidak diinginkan
        en_rx        <= '0';
        en_ram_write <= '0';
        en_fft       <= '0';
        en_mag       <= '0';
        en_tx        <= '0';
        next_state   <= current_state; 

        case current_state is
            when IDLE =>
                if rx_data_ready = '1' then
                    next_state <= FILL_BUFFER;
                end if;

            when FILL_BUFFER =>
                en_rx <= '1';
                en_ram_write <= '1';
                if buffer_full = '1' then
                    next_state <= BIT_REVERSE;
                end if;

            when BIT_REVERSE =>
                -- (Logika enable untuk bit-reverse diletakkan di sini)
                -- Untuk sementara kita asumsikan pindah ke FFT langsung jika selesai
                next_state <= FFT_COMPUTE;

            when FFT_COMPUTE =>
                en_fft <= '1';
                if fft_done = '1' then
                    next_state <= MAGNITUDE;
                end if;

            when MAGNITUDE =>
                en_mag <= '1';
                if mag_done = '1' then
                    next_state <= SEND_DATA;
                end if;

            when SEND_DATA =>
                en_tx <= '1';
                if tx_done = '1' then
                    next_state <= IDLE;
                end if;

            when others =>
                next_state <= IDLE;
        end case;
    end process;

end Behavioral;